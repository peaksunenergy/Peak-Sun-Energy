# ============================================================
# Peak Sun Energy — Environment Variables
# ============================================================
# Copy this file to .env (dev) or .env.production (prod)
# The server auto-loads .env in dev, .env.production when NODE_ENV=production

# Supabase project URL (found in Dashboard > Settings > API > Project URL)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Supabase service_role key (found in Dashboard > Settings > API > service_role)
# WARNING: This key has full admin access — never expose it to the frontend
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key

# JWT secret for auth tokens (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your-random-hex-secret-here

# Server port (default: 3000)
PORT=3000

# App URL (used in email verification links)
# Dev:  http://192.168.1.73:3000
# Prod: https://peak-sun-energy.onrender.com
APP_URL=http://192.168.1.73:3000

# CORS allowed origins (comma-separated, leave empty to allow all in dev)
# CORS_ORIGINS=https://peak-sun-energy.onrender.com

# Brevo email API (https://brevo.com → SMTP & API → API Keys)
# Free: 300 emails/day to any recipient
BREVO_API_KEY=xkeysib-your-api-key
SENDER_EMAIL=peaksunenergy23@gmail.com
SENDER_NAME=Peak Sun Energy
ADMIN_EMAIL=admin@peaksunenergy.tn

